// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MessageInfo {
  id                  String    @id @default(uuid())
  content             String
  platform_id         String
  platform            Platform  @relation(fields: [platform_id], references: [id])
  action              String
  user_id             Int
  date                DateTime  @default(now())
  score               Float
  reason_for_deletion String?   
  group_id            String
}

model Platform {
  id              String        @id @default(uuid())
  platform_name   String
  group_count     Int           @default(0)
  private_count   Int           @default(0)
  removed_members Int           @default(0)
  
  messages        MessageInfo[]
  users           User[]
}

model ThresholdParameter {
  id              String @id @default(uuid())
  threshold       Int
  under_threshold Int
  group_id        String
}

model User {
  id                    String      @id @default(uuid())
  username              String
  password              String
  
  permission_id         String
  permission            Permission  @relation(fields: [permission_id], references: [id])
  
  platform_id           String?
  platform              Platform?   @relation(fields: [platform_id], references: [id])
  
  group_id              String?
  
  members_list_messages String[]
  white_list_messages   String[]
  black_list_messages   String[]
}

model Permission {
  id              String @id @default(uuid())
  permission_name String
  
  users           User[]
}

